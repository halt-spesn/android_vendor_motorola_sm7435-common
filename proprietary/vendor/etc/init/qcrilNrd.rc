on post-fs-data
    write /data/vendor/radio/cutbackOpt disabled
    chmod 0644 /data/vendor/radio/cutbackOpt
    chown radio /data/vendor/radio/cutbackOpt

on boot
    mkdir /dev/socket/qcrild 0750 radio radio

service vendor.qcrild /vendor/bin/hw/qcrilNrd
    class main
    user radio
    disabled
    socket cutback stream 660 audioserver radio
    group radio cache inet misc audio log readproc wakelock oem_2901 oem_2912 wifi diag input vendor_thermal
    capabilities BLOCK_SUSPEND NET_ADMIN NET_RAW

service vendor.qcrild2 /vendor/bin/hw/qcrilNrd -c 2
    class main
    user radio
    disabled
    group radio cache inet misc audio log readproc wakelock oem_2901 oem_2912 vendor_thermal
    capabilities BLOCK_SUSPEND NET_ADMIN NET_RAW

service vendor.qcrild3 /vendor/bin/hw/qcrilNrd -c 3
    class main
    user radio
    disabled
    group radio cache inet misc audio log readproc wakelock oem_2901 oem_2912 vendor_thermal
    capabilities BLOCK_SUSPEND NET_ADMIN NET_RAW

on property:persist.vendor.camera.mot.cutbackOpt=enabled
   write /data/vendor/radio/cutbackOpt enabled

on property:persist.vendor.camera.mot.cutbackOpt=disabled
   write /data/vendor/radio/cutbackOpt disabled

service vendor.qcrild_service-sh /vendor/bin/init.qcrild.sh
    class main
    user root
    group root
    oneshot

on property:vold.decrypt=trigger_restart_framework
    start vendor.qcrild_service-sh

on property:persist.radio.multisim.config=ssss && property:ro.baseband=msm && property:ro.vendor.radio.noril=""
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild

on property:persist.radio.multisim.config=ssss && property:ro.baseband=mdm
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild

on property:persist.radio.multisim.config=SSSS && property:ro.baseband=msm && property:ro.vendor.radio.noril=""
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild

on property:persist.radio.multisim.config=SSSS && property:ro.baseband=mdm
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild

on property:persist.radio.multisim.config=dsds && property:ro.baseband=msm && property:ro.vendor.radio.noril=""
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild
    start vendor.qcrild2

on property:persist.radio.multisim.config=dsds && property:ro.baseband=mdm
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild
    start vendor.qcrild2

on property:persist.radio.multisim.config=DSDS && property:ro.baseband=msm && property:ro.vendor.radio.noril=""
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild
    start vendor.qcrild2

on property:persist.radio.multisim.config=DSDS && property:ro.baseband=mdm
    stop vendor.qcrild
    stop vendor.qcrild2
    start vendor.qcrild
    start vendor.qcrild2

on property:ro.boot.product.vendor.sku=tuna
    setprop persist.vendor.radio.dsds_to_ss 1
    setprop persist.vendor.radio.dsds_to_ss_timer 120000

on property:ro.boot.product.vendor.sku=kera
    setprop persist.vendor.radio.dsds_to_ss 1
    setprop persist.vendor.radio.dsds_to_ss_timer 120000